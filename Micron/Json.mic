// TODO: throws assertions, to debug

module Json

import B := Benchmark

const
    JV_OBJECT = 1
    JV_ARRAY = 2
    JV_STRING = 3
    JV_NUMBER = 4
    JV_LITERAL = 5
    HASH_TABLE_SIZE = 32

type
    JsonValue = record
        next: ^JsonValue
        kind: integer
    end

    ValArr = record
        data: ^array of ^JsonValue
        size, cap: integer
    end

    StrArr = record
        data: ^array of ^array of char
        size, cap: integer
    end

    HashIndexTable = record
        hashTable: ^array of integer
    end

    JsonObject = record
        base: JsonValue
        names: StrArr
        values: ValArr
        table: HashIndexTable
    end

    JsonArray = record
        base: JsonValue
        values: ValArr
    end

    Str = ^array of char

    JsonString = record
        base: JsonValue
        str: Str
    end

    JsonNumber = record
        base: JsonValue
        str: Str
    end

    JsonLiteral = record
        base: JsonValue
        isNull_: boolean
        isTrue_: boolean
        isFalse_: boolean
    end

    StringBuffer = record
        buf: Str
        len: integer
        pos: integer
    end

    Parser = record
        input: Str
        inputLen: integer
        index: integer
        line: integer
        column: integer
        current: char
        captureBuffer: StringBuffer
        captureStart: integer
        nullValue: ^JsonValue
        trueValue: ^JsonValue
        falseValue: ^JsonValue
    end
    
var
    toDelete: ^JsonValue
    parseResult: ^JsonValue

procedure^ readValue(me: ^Parser): ^JsonValue

procedure ValArr_init(me: ^ValArr)
begin
    me.data := nil
    me.size := 0
    me.cap := 0
end ValArr_init

procedure ValArr_append(me: ^ValArr; p: ^JsonValue)
var old: ^array of ^JsonValue; i: integer
begin
    if me.size >= me.cap then
        if me.cap = 0 then me.cap := 4
        else me.cap := me.cap * 2 end
        old := me.data
        new(me.data, me.cap)
        if old # nil then
            for i := 0 to me.size - 1 do me.data[i] := old[i] end
            dispose(old)
        end
    end
    me.data[me.size] := p
    inc(me.size)
end ValArr_append

procedure ValArr_at(me: ^ValArr; idx: integer): ^JsonValue
begin
    return me.data[idx]
end ValArr_at

procedure ValArr_size(me: ^ValArr): integer
begin
    return me.size
end ValArr_size

procedure ValArr_free(me: ^ValArr)
begin
    if me.data # nil then dispose(me.data) end
end ValArr_free

procedure StrArr_init(me: ^StrArr)
begin
    me.data := nil
    me.size := 0
    me.cap := 0
end StrArr_init

procedure StrArr_append(me: ^StrArr; p: ^array of char)
var old: ^array of ^array of char; i: integer
begin
    if me.size >= me.cap then
        if me.cap = 0 then me.cap := 4
        else me.cap := me.cap * 2 end
        old := me.data
        new(me.data, me.cap)
        if old # nil then
            for i := 0 to me.size - 1 do me.data[i] := old[i] end
            dispose(old)
        end
    end
    me.data[me.size] := p
    inc(me.size)
end StrArr_append

procedure StrArr_at(me: ^StrArr; idx: integer): Str
begin
    return me.data[idx]
end StrArr_at

procedure StrArr_size(me: ^StrArr): integer
begin
    return me.size
end StrArr_size

procedure StrArr_free(me: ^StrArr)
begin
    if me.data # nil then dispose(me.data) end
end StrArr_free

procedure HashIndexTable_init(me: ^HashIndexTable)
var i: integer
begin
    new(me.hashTable, HASH_TABLE_SIZE)
    for i := 0 to HASH_TABLE_SIZE - 1 do
        me.hashTable[i] := 0
    end
end HashIndexTable_init

procedure HashIndexTable_stringHash(s: ^array of char): integer
begin
    return sig(strlen(s) * 1402589)
end HashIndexTable_stringHash

procedure HashIndexTable_hashSlotFor(s: ^array of char): integer
begin
    return band(HashIndexTable_stringHash(s), sig(HASH_TABLE_SIZE - 1))
end HashIndexTable_hashSlotFor

procedure HashIndexTable_get(me: ^HashIndexTable; name: ^array of char): integer
var slot: integer
begin
    slot := HashIndexTable_hashSlotFor(name)
    return band(me.hashTable[slot], 0FFH) - 1
end HashIndexTable_get

procedure HashIndexTable_add(me: ^HashIndexTable; name: ^array of char; index: integer)
var slot: integer
begin
    slot := HashIndexTable_hashSlotFor(name)
    if index < 0FFH then
        me.hashTable[slot] := band(index + 1, 0FFH)
    else
        me.hashTable[slot] := 0
    end
end HashIndexTable_add

procedure StringBuffer_init(me: ^StringBuffer)
begin
    me.buf := nil
    me.len := 0
    me.pos := 0
end StringBuffer_init

procedure StringBuffer_append(me: ^StringBuffer; src: ^array of char; start, count: integer)
var i: integer; old: ^array of char
begin
    if me.buf = nil then
        me.len := 2 * count
        if me.len < 16 then me.len := 16 end
        new(me.buf, me.len)
        for i := 0 to count - 1 do
            me.buf[i] := src[start + i]
        end
        me.pos := count
    else
        if me.pos + count + 1 > me.len then
            old := me.buf
            me.len := me.len * 2
            new(me.buf, me.len)
            for i := 0 to me.pos - 1 do me.buf[i] := old[i] end
            dispose(old)
        end
        for i := 0 to count - 1 do
            me.buf[me.pos + i] := src[start + i]
        end
        me.pos := me.pos + count
    end
end StringBuffer_append

procedure StringBuffer_appendChar(me: ^StringBuffer; ch: char)
var old: ^array of char; i: integer
begin
    if me.buf = nil then
        me.len := 16
        new(me.buf, me.len)
        me.buf[0] := ch
        me.pos := 1
    else
        if me.pos + 2 > me.len then
            old := me.buf
            me.len := me.len * 2
            new(me.buf, me.len)
            for i := 0 to me.pos - 1 do me.buf[i] := old[i] end
            dispose(old)
        end
        me.buf[me.pos] := ch
        inc(me.pos)
    end
end StringBuffer_appendChar

procedure JsonObject_create(): ^JsonObject
var me: ^JsonObject
begin
    new(me)
    me.base.kind := JV_OBJECT
    me.base.next := toDelete
    toDelete := @me.base
    ValArr_init(@me.values)
    StrArr_init(@me.names)
    HashIndexTable_init(@me.table)
    return me
end JsonObject_create

procedure JsonObject_add(me: ^JsonObject; name: ^array of char; value: ^JsonValue)
begin
    HashIndexTable_add(@me.table, name, StrArr_size(@me.names))
    StrArr_append(@me.names, name)
    ValArr_append(@me.values, value)
end JsonObject_add

procedure JsonObject_indexOf(me: ^JsonObject; name: ^array of char): integer
var index: integer
begin
    index := HashIndexTable_get(@me.table, name)
    if (index # -1) and (StrArr_at(@me.names, index) = name) then
        return index
    end
    assert(false)
    return -1
end JsonObject_indexOf

procedure JsonObject_get(me: ^JsonObject; const name: ^array of char): ^JsonValue
var index: integer
begin
    index := JsonObject_indexOf(me, name)
    if index = -1 then return nil end
    return ValArr_at(@me.values, index)
end JsonObject_get

procedure JsonObject_size(me: ^JsonObject): integer
begin
    return StrArr_size(@me.names)
end JsonObject_size

procedure JsonObject_cleanup(me: ^JsonObject)
var i: integer
begin
    dispose(me.table.hashTable)
    for i := 0 to StrArr_size(@me.names) - 1 do
        dispose(StrArr_at(@me.names, i))
    end
    StrArr_free(@me.names)
    ValArr_free(@me.values)
end JsonObject_cleanup

procedure JsonArray_create(): ^JsonArray
var me: ^JsonArray
begin
    new(me)
    me.base.kind := JV_ARRAY
    me.base.next := toDelete
    toDelete := @me.base
    ValArr_init(@me.values)
    return me
end JsonArray_create

procedure JsonArray_add(me: ^JsonArray; value: ^JsonValue)
begin
    ValArr_append(@me.values, value)
end JsonArray_add

procedure JsonArray_size(me: ^JsonArray): integer
begin
    return ValArr_size(@me.values)
end JsonArray_size

procedure JsonArray_cleanup(me: ^JsonArray)
begin
    ValArr_free(@me.values)
end JsonArray_cleanup

procedure JsonString_create(str: ^array of char): ^JsonValue
var me: ^JsonString
begin
    new(me)
    me.base.kind := JV_STRING
    me.base.next := toDelete
    toDelete := @me.base
    me.str := str
    return @me.base
end JsonString_create

procedure JsonString_cleanup(me: ^JsonString)
begin
    dispose(me.str)
end JsonString_cleanup

procedure JsonNumber_create(str: ^array of char): ^JsonValue
var me: ^JsonNumber
begin
    new(me)
    me.base.kind := JV_NUMBER
    me.base.next := toDelete
    toDelete := @me.base
    me.str := str
    return @me.base
end JsonNumber_create

procedure JsonNumber_cleanup(me: ^JsonNumber)
begin
    dispose(me.str)
end JsonNumber_cleanup

procedure JsonLiteral_create(const value: ^array of char): ^JsonValue
var me: ^JsonLiteral
begin
    new(me)
    me.base.kind := JV_LITERAL
    me.base.next := toDelete
    toDelete := @me.base
    me.isNull_ := (value = "null")
    me.isTrue_ := (value = "true")
    me.isFalse_ := (value = "false")
    return @me.base
end JsonLiteral_create

procedure JsonValue_delete(o: ^JsonValue)
begin
    if o = nil then return end
    if o.next # nil then
        JsonValue_delete(o.next)
    end
    if o.kind = JV_OBJECT then
        JsonObject_cleanup(o(JsonObject))
    elsif o.kind = JV_ARRAY then
        JsonArray_cleanup(o(JsonArray))
    elsif o.kind = JV_STRING then
        JsonString_cleanup(o(JsonString))
    elsif o.kind = JV_NUMBER then
        JsonNumber_cleanup(o(JsonNumber))
    end
    dispose(o)
end JsonValue_delete

procedure Parser_init(me: ^Parser; const str: ^array of char)
begin
    me.input := str
    me.inputLen := sig(strlen(str))
    me.index := -1
    me.line := 1
    me.captureStart := -1
    me.column := 0
    StringBuffer_init(@me.captureBuffer)
    me.nullValue := JsonLiteral_create("null")
    me.trueValue := JsonLiteral_create("true")
    me.falseValue := JsonLiteral_create("false")
    me.current := 0X
end Parser_init

procedure Parser_deinit(me: ^Parser)
begin
    if me.captureBuffer.buf # nil then
        dispose(me.captureBuffer.buf)
    end
end Parser_deinit

procedure Parser_isWhiteSpace(me: ^Parser): boolean
begin
    return (me.current = " ") or (me.current = 9X) or (me.current = 0AX) or (me.current = 0DX)
end Parser_isWhiteSpace

procedure Parser_isDigit(me: ^Parser): boolean
var ch: char
begin
    ch := me.current
    return (ch >= "0") and (ch <= "9")
end Parser_isDigit

procedure Parser_read(me: ^Parser)
begin
    if me.current = 0AX then
        inc(me.line)
        me.column := 0
    end
    inc(me.index)
    if me.index < me.inputLen then
        me.current := me.input[me.index]
    else
        me.current := 0X
    end
end Parser_read

procedure Parser_readChar(me: ^Parser; ch: char): boolean
begin
    if me.current # ch then
        return false
    end
    Parser_read(me)
    return true
end Parser_readChar

procedure Parser_readRequiredChar(me: ^Parser; ch: char)
begin
    if not Parser_readChar(me, ch) then
        assert(false)
    end
end Parser_readRequiredChar

procedure Parser_readDigit(me: ^Parser): boolean
begin
    if not Parser_isDigit(me) then
        return false
    end
    Parser_read(me)
    return true
end Parser_readDigit

procedure Parser_skipWhiteSpace(me: ^Parser)
begin
    while Parser_isWhiteSpace(me) do
        Parser_read(me)
    end
end Parser_skipWhiteSpace

procedure Parser_startCapture(me: ^Parser)
begin
    me.captureStart := me.index
end Parser_startCapture

procedure Parser_pauseCapture(me: ^Parser)
var end_: integer
begin
    if me.current = 0X then end_ := me.index
    else end_ := me.index - 1 end
    StringBuffer_append(@me.captureBuffer, me.input, me.captureStart, end_ + 1 - me.captureStart)
    me.captureStart := -1
end Parser_pauseCapture

procedure Parser_endCapture(me: ^Parser): Str
var end_, captLen, i: integer; captured: Str
begin
    if me.current = 0X then end_ := me.index
    else end_ := me.index - 1 end
    StringBuffer_append(@me.captureBuffer, me.input, me.captureStart, end_ + 1 - me.captureStart)
    captLen := me.captureBuffer.pos
    new(captured, captLen + 1)
    for i := 0 to captLen - 1 do
        captured[i] := me.captureBuffer.buf[i]
    end
    captured[captLen] := 0X
    if me.captureBuffer.buf # nil then
        dispose(me.captureBuffer.buf)
    end
    StringBuffer_init(@me.captureBuffer)
    me.captureStart := -1
    return captured
end Parser_endCapture

procedure Parser_readEscape(me: ^Parser)
begin
    Parser_read(me)
    if me.current = '"' then
        StringBuffer_appendChar(@me.captureBuffer, '"')
    elsif me.current = "/" then
        StringBuffer_appendChar(@me.captureBuffer, "/")
    elsif me.current = 5CX then
        StringBuffer_appendChar(@me.captureBuffer, 5CX)
    elsif me.current = "b" then
        StringBuffer_appendChar(@me.captureBuffer, 8X)
    elsif me.current = "f" then
        StringBuffer_appendChar(@me.captureBuffer, 0CX)
    elsif me.current = "n" then
        StringBuffer_appendChar(@me.captureBuffer, 0AX)
    elsif me.current = "r" then
        StringBuffer_appendChar(@me.captureBuffer, 0DX)
    elsif me.current = "t" then
        StringBuffer_appendChar(@me.captureBuffer, 9X)
    else
        assert(false)
    end
    Parser_read(me)
end Parser_readEscape

procedure Parser_readStringInternal(me: ^Parser): Str
var str: Str
begin
    Parser_read(me)
    Parser_startCapture(me)
    while me.current # '"' do
        if me.current = 5CX then
            Parser_pauseCapture(me)
            Parser_readEscape(me)
            Parser_startCapture(me)
        else
            Parser_read(me)
        end
    end
    str := Parser_endCapture(me)
    Parser_read(me)
    return str
end Parser_readStringInternal

procedure Parser_readFraction(me: ^Parser): boolean
begin
    if not Parser_readChar(me, ".") then
        return false
    end
    if not Parser_readDigit(me) then
        assert(false)
    end
    while Parser_readDigit(me) do end
    return true
end Parser_readFraction

procedure Parser_readExponent(me: ^Parser): boolean
begin
    if (not Parser_readChar(me, "e")) and (not Parser_readChar(me, "E")) then
        return false
    end
    if not Parser_readChar(me, "+") then
        Parser_readChar(me, "-")
    end
    if not Parser_readDigit(me) then
        assert(false)
    end
    while Parser_readDigit(me) do end
    return true
end Parser_readExponent

procedure Parser_readNumber(me: ^Parser): ^JsonValue
var firstDigit: char
begin
    Parser_startCapture(me)
    Parser_readChar(me, "-")
    firstDigit := me.current
    if not Parser_readDigit(me) then
        assert(false)
    end
    if firstDigit # "0" then
        while Parser_readDigit(me) do end
    end
    Parser_readFraction(me)
    Parser_readExponent(me)
    return JsonNumber_create(Parser_endCapture(me))
end Parser_readNumber

procedure Parser_readName(me: ^Parser): Str
begin
    if me.current # '"' then
        assert(false)
    end
    return Parser_readStringInternal(me)
end Parser_readName

procedure Parser_readString(me: ^Parser): ^JsonValue
begin
    return JsonString_create(Parser_readStringInternal(me))
end Parser_readString

procedure Parser_readNull(me: ^Parser): ^JsonValue
begin
    Parser_read(me)
    Parser_readRequiredChar(me, "u")
    Parser_readRequiredChar(me, "l")
    Parser_readRequiredChar(me, "l")
    return me.nullValue
end Parser_readNull

procedure Parser_readTrue(me: ^Parser): ^JsonValue
begin
    Parser_read(me)
    Parser_readRequiredChar(me, "r")
    Parser_readRequiredChar(me, "u")
    Parser_readRequiredChar(me, "e")
    return me.trueValue
end Parser_readTrue

procedure Parser_readFalse(me: ^Parser): ^JsonValue
begin
    Parser_read(me)
    Parser_readRequiredChar(me, "a")
    Parser_readRequiredChar(me, "l")
    Parser_readRequiredChar(me, "s")
    Parser_readRequiredChar(me, "e")
    return me.falseValue
end Parser_readFalse

procedure Parser_readArray(me: ^Parser): ^JsonValue
var arr: ^JsonArray
begin
    Parser_read(me)
    arr := JsonArray_create()
    Parser_skipWhiteSpace(me)
    if Parser_readChar(me, "]") then
        return @arr.base
    end
    loop
        Parser_skipWhiteSpace(me)
        JsonArray_add(arr, readValue(me))
        Parser_skipWhiteSpace(me)
        if not Parser_readChar(me, ",") then exit end
    end
    if not Parser_readChar(me, "]") then
        assert(false)
    end
    return @arr.base
end Parser_readArray

procedure Parser_readObject(me: ^Parser): ^JsonValue
var obj: ^JsonObject; name: ^array of char
begin
    Parser_read(me)
    obj := JsonObject_create()
    Parser_skipWhiteSpace(me)
    if Parser_readChar(me, "}") then
        return @obj.base
    end
    loop
        Parser_skipWhiteSpace(me)
        name := Parser_readName(me)
        Parser_skipWhiteSpace(me)
        if not Parser_readChar(me, ":") then
            assert(false)
        end
        Parser_skipWhiteSpace(me)
        JsonObject_add(obj, name, readValue(me))
        Parser_skipWhiteSpace(me)
        if not Parser_readChar(me, ",") then exit end
    end
    if not Parser_readChar(me, "}") then
        assert(false)
    end
    return @obj.base
end Parser_readObject

procedure readValue(me: ^Parser): ^JsonValue
begin
    if me.current = "n" then
        return Parser_readNull(me)
    elsif me.current = "t" then
        return Parser_readTrue(me)
    elsif me.current = "f" then
        return Parser_readFalse(me)
    elsif me.current = '"' then
        return Parser_readString(me)
    elsif me.current = "[" then
        return Parser_readArray(me)
    elsif me.current = "{" then
        return Parser_readObject(me)
    elsif (me.current = "-") or ((me.current >= "0") and (me.current <= "9")) then
        return Parser_readNumber(me)
    else
        assert(false)
        return nil
    end
end readValue

procedure Parser_parse(me: ^Parser): ^JsonValue
var res: ^JsonValue
begin
    Parser_read(me)
    Parser_skipWhiteSpace(me)
    res := readValue(me)
    Parser_skipWhiteSpace(me)
    if me.current # 0X then
        assert(false)
    end
    return res
end Parser_parse

