procedure benchmark(me: ^B.Benchmark): integer
var p: Parser
begin
    Parser_init(@p, rapBenchmark)
    parseResult := Parser_parse(@p)
    Parser_deinit(@p)
    return 0
end benchmark

procedure verifyResult(me: ^B.Benchmark; r: integer): boolean
var res: boolean; tmp: ^JsonValue
begin
    res := false
    if parseResult = nil then
        res := false
    elsif parseResult.kind # JV_OBJECT then
        res := false
    else
        tmp := JsonObject_get(parseResult(JsonObject), "head")
        if (tmp = nil) or (tmp.kind # JV_OBJECT) then
            res := false
        else
            tmp := JsonObject_get(parseResult(JsonObject), "operations")
            if (tmp = nil) or (tmp.kind # JV_ARRAY) then
                res := false
            else
                res := JsonArray_size(tmp(JsonArray)) = 156
            end
        end
    end
    JsonValue_delete(toDelete)
    toDelete := nil
    parseResult := nil
    return res
end verifyResult

procedure create*(): ^B.Benchmark
var bench: ^B.Benchmark
begin
    new(bench)
    bench.benchmark := benchmark
    bench.verifyResult := verifyResult
    bench.dispose := nil
    bench.innerBenchmarkLoop := nil
    return bench
end create

end Json
