module RedBlackTree(K, V) [level=3]

const
    RED = 0
    BLACK = 1

type
    Compare* = proc(const lhs, rhs: ^K): integer
    KeyValueIterator* = proc (^)(const key: ^K; const value: ^V)

    Node = pointer to NodeDesc
    NodeDesc = record
        key: K
        value: V
        left: Node
        right: Node
        parent: Node
        color: integer
    end

    Tree* = pointer to TreeDesc
    TreeDesc* = record
        root: Node
        compare: Compare
        isNewEntry: boolean
        newNode: Node
        oldValue: ^V
        hasOldValue: boolean
        oldValueStore: V
    end

proc Node_create(const key: ^K; const value: ^V): Node
var me: Node
begin
    new(me)
    me.key := key^
    me.value := value^
    me.left := nil
    me.right := nil
    me.parent := nil
    me.color := RED
    return me
end Node_create

proc Node_dispose(me: Node)
begin
    if me = nil then return end
    if me.left # nil then Node_dispose(me.left) end
    if me.right # nil then Node_dispose(me.right) end
    dispose(me)
end Node_dispose

proc Node_treeMinimum(x: Node): Node
var current: Node
begin
    current := x
    while current.left # nil do
        current := current.left
    end
    return current
end Node_treeMinimum

proc Node_successor(me: Node): Node
var x, y: Node
begin
    x := me
    if x.right # nil then
        return Node_treeMinimum(x.right)
    end
    y := x.parent
    while (y # nil) and (x = y.right) do
        x := y
        y := y.parent
    end
    return y
end Node_successor

proc create*(cmp: Compare): Tree
var me: Tree
begin
    new(me)
    me.root := nil
    me.compare := cmp
    me.isNewEntry := false
    me.newNode := nil
    me.oldValue := nil
    me.hasOldValue := false
    return me
end create

procedure TreeDesc.free*()
begin
    if self = nil then return end
    if self.root # nil then Node_dispose(self.root) end
    dispose(self)
end free

procedure TreeDesc.findNode(const key: ^K): Node
var current: Node; cmp: integer
begin
    current := self.root
    while current # nil do
        cmp := self.compare(@current.key, key)
        if cmp = 0 then return current end
        if cmp > 0 then
            current := current.left
        else
            current := current.right
        end
    end
    return nil
end findNode

procedure TreeDesc.treeInsert(const key: ^K; const value: ^V)
var y, x: Node; cmp: integer; z: Node
begin
    y := nil
    x := self.root

    while x # nil do
        y := x
        cmp := self.compare(key, @x.key)
        if cmp < 0 then
            x := x.left
        elsif cmp > 0 then
            x := x.right
        else
            self.oldValueStore := x.value
            self.oldValue := @self.oldValueStore
            self.hasOldValue := true
            x.value := value^
            self.isNewEntry := false
            self.newNode := nil
            return
        end
    end

    z := Node_create(key, value)
    z.parent := y
    if y = nil then
        self.root := z
    else
        if self.compare(key, @y.key) < 0 then
            y.left := z
        else
            y.right := z
        end
    end
    self.isNewEntry := true
    self.newNode := z
    self.oldValue := nil
    self.hasOldValue := false
end treeInsert

procedure TreeDesc.leftRotate(x: Node): Node
var y: Node
begin
    y := x.right
    x.right := y.left
    if y.left # nil then
        y.left.parent := x
    end
    y.parent := x.parent
    if x.parent = nil then
        self.root := y
    else
        if x = x.parent.left then
            x.parent.left := y
        else
            x.parent.right := y
        end
    end
    y.left := x
    x.parent := y
    return y
end leftRotate

procedure TreeDesc.rightRotate(y: Node): Node
var x: Node
begin
    x := y.left
    y.left := x.right
    if x.right # nil then
        x.right.parent := y
    end
    x.parent := y.parent
    if y.parent = nil then
        self.root := x
    else
        if y = y.parent.left then
            y.parent.left := x
        else
            y.parent.right := x
        end
    end
    x.right := y
    y.parent := x
    return x
end rightRotate

procedure TreeDesc.removeFixup(x_, xParent_: Node)
var x, xParent, w: Node
begin
    x := x_
    xParent := xParent_
    while (x # self.root) and ((x = nil) or (x.color = BLACK)) do
        if x = xParent.left then
            w := xParent.right
            if w.color = RED then
                w.color := BLACK
                xParent.color := RED
                self.leftRotate(xParent)
                w := xParent.right
            end
            if ((w.left = nil) or (w.left.color = BLACK)) and ((w.right = nil) or (w.right.color = BLACK)) then
                w.color := RED
                x := xParent
                xParent := x.parent
            else
                if (w.right = nil) or (w.right.color = BLACK) then
                    w.left.color := BLACK
                    w.color := RED
                    self.rightRotate(w)
                    w := xParent.right
                end
                w.color := xParent.color
                xParent.color := BLACK
                if w.right # nil then
                    w.right.color := BLACK
                end
                self.leftRotate(xParent)
                x := self.root
                xParent := x.parent
            end
        else
            w := xParent.left
            if w.color = RED then
                w.color := BLACK
                xParent.color := RED
                self.rightRotate(xParent)
                w := xParent.left
            end
            if ((w.right = nil) or (w.right.color = BLACK)) and ((w.left = nil) or (w.left.color = BLACK)) then
                w.color := RED
                x := xParent
                xParent := x.parent
            else
                if (w.left = nil) or (w.left.color = BLACK) then
                    w.right.color := BLACK
                    w.color := RED
                    self.leftRotate(w)
                    w := xParent.left
                end
                w.color := xParent.color
                xParent.color := BLACK
                if w.left # nil then
                    w.left.color := BLACK
                end
                self.rightRotate(xParent)
                x := self.root
                xParent := x.parent
            end
        end
    end
    if x # nil then
        x.color := BLACK
    end
end removeFixup

procedure TreeDesc.put*(const key: ^K; const value: ^V): ^V
var x, y: Node
begin
    self.treeInsert(key, value)
    if not self.isNewEntry then
        return self.oldValue
    end
    x := self.newNode

    while (x # self.root) and (x.parent.color = RED) do
        if x.parent = x.parent.parent.left then
            y := x.parent.parent.right
            if (y # nil) and (y.color = RED) then
                x.parent.color := BLACK
                y.color := BLACK
                x.parent.parent.color := RED
                x := x.parent.parent
            else
                if x = x.parent.right then
                    x := x.parent
                    self.leftRotate(x)
                end
                x.parent.color := BLACK
                x.parent.parent.color := RED
                self.rightRotate(x.parent.parent)
            end
        else
            y := x.parent.parent.left
            if (y # nil) and (y.color = RED) then
                x.parent.color := BLACK
                y.color := BLACK
                x.parent.parent.color := RED
                x := x.parent.parent
            else
                if x = x.parent.left then
                    x := x.parent
                    self.rightRotate(x)
                end
                x.parent.color := BLACK
                x.parent.parent.color := RED
                self.leftRotate(x.parent.parent)
            end
        end
    end

    self.root.color := BLACK
    return nil
end put

procedure TreeDesc.remove*(const key: ^K): ^V
var z, y, x, xParent: Node
begin
    z := self.findNode(key)
    if z = nil then return nil end

    if (z.left = nil) or (z.right = nil) then
        y := z
    else
        y := Node_successor(z)
    end

    if y.left # nil then
        x := y.left
    else
        x := y.right
    end

    if x # nil then
        x.parent := y.parent
        xParent := x.parent
    else
        xParent := y.parent
    end

    if y.parent = nil then
        self.root := x
    else
        if y = y.parent.left then
            y.parent.left := x
        else
            y.parent.right := x
        end
    end

    if y # z then
        if y.color = BLACK then
            self.removeFixup(x, xParent)
        end
        y.parent := z.parent
        y.color := z.color
        y.left := z.left
        y.right := z.right
        if z.left # nil then z.left.parent := y end
        if z.right # nil then z.right.parent := y end
        if z.parent # nil then
            if z.parent.left = z then
                z.parent.left := y
            else
                z.parent.right := y
            end
        else
            self.root := y
        end
    elsif y.color = BLACK then
        self.removeFixup(x, xParent)
    end

    self.oldValueStore := z.value
    dispose(z)
    return @self.oldValueStore
end remove

procedure TreeDesc.get*(const key: ^K): ^V
var node: Node
begin
    node := self.findNode(key)
    if node = nil then return nil end
    return @node.value
end get

procedure TreeDesc.forEach*(iter: KeyValueIterator)
var current: Node
begin
    if self.root = nil then return end
    current := Node_treeMinimum(self.root)
    while current # nil do
        iter(@current.key, @current.value)
        current := Node_successor(current)
    end
end forEach

end RedBlackTree
