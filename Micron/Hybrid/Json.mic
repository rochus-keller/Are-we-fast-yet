module Json [level=3]

import B := Benchmark

const
    JV_OBJECT = 1
    JV_ARRAY = 2
    JV_STRING = 3
    JV_NUMBER = 4
    JV_LITERAL = 5
    HASH_TABLE_SIZE = 32

type
    JsonValue = record
        next: ^JsonValue
        kind: integer
    end

    ValArr = record
        data: ^array of ^JsonValue
        size_, cap: integer
    end

    StrArr = record
        data: ^array of ^array of char
        size_, cap: integer
    end

    HashIndexTable = record
        hashTable: ^array of integer
    end

    JsonObject = record
        inline base: JsonValue
        names: StrArr
        values: ValArr
        table: HashIndexTable
    end

    JsonArray = record
        inline base: JsonValue
        values: ValArr
    end

    Str = ^array of char

    JsonString = record
        inline base: JsonValue
        str: Str
    end

    JsonNumber = record
        inline base: JsonValue
        str: Str
    end

    JsonLiteral = record
        inline base: JsonValue
        isNull_: boolean
        isTrue_: boolean
        isFalse_: boolean
    end

    StringBuffer = record
        buf: Str
        len: integer
        pos: integer
    end

    Parser = record
        input: Str
        inputLen: integer
        index: integer
        line: integer
        column: integer
        current: char
        captureBuffer: StringBuffer
        captureStart: integer
        nullValue: ^JsonValue
        trueValue: ^JsonValue
        falseValue: ^JsonValue
    end
    
var
    toDelete: ^JsonValue
    parseResult: ^JsonValue

procedure^ Parser.readValue(): ^JsonValue

procedure ValArr.init()
begin
    self.data := nil
    self.size_ := 0
    self.cap := 0
end ValArr.init

procedure ValArr.append(p: ^JsonValue)
var old: ^array of ^JsonValue; i: integer
begin
    if self.size_ >= self.cap then
        if self.cap = 0 then self.cap := 4
        else self.cap := self.cap * 2 end
        old := self.data
        new(self.data, self.cap)
        if old # nil then
            for i := 0 to self.size_ - 1 do self.data[i] := old[i] end
            dispose(old)
        end
    end
    self.data[self.size_] := p
    inc(self.size_)
end ValArr.append

procedure ValArr.at(idx: integer): ^JsonValue
begin
    return self.data[idx]
end ValArr.at

procedure ValArr.size(): integer
begin
    return self.size_
end ValArr.size

procedure ValArr.free()
begin
    if self.data # nil then dispose(self.data) end
end ValArr.free

procedure StrArr.init()
begin
    self.data := nil
    self.size_ := 0
    self.cap := 0
end StrArr.init

procedure StrArr.append(p: ^array of char)
var old: ^array of ^array of char; i: integer
begin
    if self.size_ >= self.cap then
        if self.cap = 0 then self.cap := 4
        else self.cap := self.cap * 2 end
        old := self.data
        new(self.data, self.cap)
        if old # nil then
            for i := 0 to self.size_ - 1 do self.data[i] := old[i] end
            dispose(old)
        end
    end
    self.data[self.size_] := p
    inc(self.size_)
end StrArr.append

procedure StrArr.at(idx: integer): Str
begin
    return self.data[idx]
end StrArr.at

procedure StrArr.size(): integer
begin
    return self.size_
end StrArr.size

procedure StrArr.free()
begin
    if self.data # nil then dispose(self.data) end
end StrArr.free

procedure HashIndexTable.init()
var i: integer
begin
    new(self.hashTable, HASH_TABLE_SIZE)
    for i := 0 to HASH_TABLE_SIZE - 1i do
        self.hashTable[i] := 0
    end
end HashIndexTable.init

procedure HashIndexTable_stringHash(s: ^array of char): integer
begin
    return sig(strlen(s) * 1402589)
end HashIndexTable_stringHash

procedure HashIndexTable_hashSlotFor(s: ^array of char): integer
begin
    return band(HashIndexTable_stringHash(s), sig(HASH_TABLE_SIZE - 1))
end HashIndexTable_hashSlotFor

procedure HashIndexTable.get(name: ^array of char): integer
var slot: integer
begin
    slot := HashIndexTable_hashSlotFor(name)
    return band(self.hashTable[slot], 0FFH) - 1
end HashIndexTable.get

procedure HashIndexTable.add(name: ^array of char; index: integer)
var slot: integer
begin
    slot := HashIndexTable_hashSlotFor(name)
    if index < 0FFH then
        self.hashTable[slot] := band(index + 1, 0FFH)
    else
        self.hashTable[slot] := 0
    end
end HashIndexTable.add

procedure StringBuffer.init()
begin
    self.buf := nil
    self.len := 0
    self.pos := 0
end StringBuffer.init

procedure StringBuffer.append(src: ^array of char; start, count: integer)
var i: integer; old: ^array of char
begin
    if self.buf = nil then
        self.len := 2 * count
        if self.len < 16 then self.len := 16 end
        new(self.buf, self.len)
        for i := 0 to count - 1 do
            self.buf[i] := src[start + i]
        end
        self.pos := count
    else
        if self.pos + count + 1 > self.len then
            old := self.buf
            self.len := self.len * 2
            new(self.buf, self.len)
            for i := 0 to self.pos - 1 do self.buf[i] := old[i] end
            dispose(old)
        end
        for i := 0 to count - 1 do
            self.buf[self.pos + i] := src[start + i]
        end
        self.pos := self.pos + count
    end
end StringBuffer.append

procedure StringBuffer.appendChar(ch: char)
var old: ^array of char; i: integer
begin
    if self.buf = nil then
        self.len := 16
        new(self.buf, self.len)
        self.buf[0] := ch
        self.pos := 1
    else
        if self.pos + 2 > self.len then
            old := self.buf
            self.len := self.len * 2
            new(self.buf, self.len)
            for i := 0 to self.pos - 1 do self.buf[i] := old[i] end
            dispose(old)
        end
        self.buf[self.pos] := ch
        inc(self.pos)
    end
end StringBuffer.appendChar

procedure JsonObject_create(): ^JsonObject
var me: ^JsonObject
begin
    new(me)
    me.kind := JV_OBJECT
    me.next := toDelete
    toDelete := @me.base
    me.values.init()
    me.names.init()
    me.table.init()
    return me
end JsonObject_create

procedure JsonObject.add(name: ^array of char; value: ^JsonValue)
begin
    self.table.add(name, self.names.size())
    self.names.append(name)
    self.values.append(value)
end JsonObject.add

procedure JsonObject.indexOf(name: ^array of char): integer
var index: integer
begin
    index := self.table.get(name)
    if (index # -1) and (self.names.at(index)^ = name^) then
        return index
    end
    assert(false)
    return -1
end JsonObject.indexOf

procedure JsonObject.get(const name: ^array of char): ^JsonValue
var index: integer
begin
    index := self.indexOf(name)
    if index = -1 then return nil end
    return self.values.at(index)
end JsonObject.get

procedure JsonObject.size(): integer
begin
    return self.names.size()
end JsonObject.size

procedure JsonObject.cleanup()
var i: integer
begin
    dispose(self.table.hashTable)
    for i := 0 to self.names.size() - 1 do
        dispose(self.names.at(i))
    end
    self.names.free()
    self.values.free()
end JsonObject.cleanup

procedure JsonArray_create(): ^JsonArray
var me: ^JsonArray
begin
    new(me)
    me.kind := JV_ARRAY
    me.next := toDelete
    toDelete := @me.base
    me.values.init()
    return me
end JsonArray_create

procedure JsonArray.add(value: ^JsonValue)
begin
    self.values.append(value)
end JsonArray.add

procedure JsonArray.size(): integer
begin
    return self.values.size()
end JsonArray.size

procedure JsonArray.cleanup()
begin
    self.values.free()
end JsonArray.cleanup

procedure JsonString_create(str: ^array of char): ^JsonValue
var me: ^JsonString
begin
    new(me)
    me.kind := JV_STRING
    me.next := toDelete
    toDelete := @me.base
    me.str := str
    return me
end JsonString_create

procedure JsonString.cleanup()
begin
    dispose(self.str)
end JsonString.cleanup

procedure JsonNumber_create(str: ^array of char): ^JsonValue
var me: ^JsonNumber
begin
    new(me)
    me.kind := JV_NUMBER
    me.next := toDelete
    toDelete := @me.base
    me.str := str
    return me
end JsonNumber_create

procedure JsonNumber.cleanup()
begin
    dispose(self.str)
end JsonNumber.cleanup

procedure JsonLiteral_create(const value: ^array of char): ^JsonValue
var me: ^JsonLiteral
begin
    new(me)
    me.kind := JV_LITERAL
    me.next := toDelete
    toDelete := @me.base
    me.isNull_ := (value^ = "null")
    me.isTrue_ := (value^ = "true")
    me.isFalse_ := (value^ = "false")
    return me
end JsonLiteral_create

procedure JsonValue_delete(o: ^JsonValue)
var next: ^JsonValue
begin
  while o # nil do
    next := o.next
    if o.kind = JV_OBJECT then
        cast(@JsonObject,o).cleanup()
    elsif o.kind = JV_ARRAY then
        cast(@JsonArray,o).cleanup()
    elsif o.kind = JV_STRING then
        cast(@JsonString,o).cleanup()
    elsif o.kind = JV_NUMBER then
        cast(@JsonNumber,o).cleanup()
    end
    dispose(o)
    o := next
  end
end JsonValue_delete

procedure Parser.init(const str: ^array of char)
begin
    self.input := str
    self.inputLen := sig(strlen(str))
    self.index := -1
    self.line := 1
    self.captureStart := -1
    self.column := 0
    self.captureBuffer.init()
    self.nullValue := JsonLiteral_create("null")
    self.trueValue := JsonLiteral_create("true")
    self.falseValue := JsonLiteral_create("false")
    self.current := 0X
end Parser.init

procedure Parser.deinit()
begin
    if self.captureBuffer.buf # nil then
        dispose(self.captureBuffer.buf)
    end
end Parser.deinit

procedure Parser.isWhiteSpace(): boolean
begin
    return (self.current = " ") or (self.current = 9X) or (self.current = 0AX) or (self.current = 0DX)
end Parser.isWhiteSpace

procedure Parser.isDigit(): boolean
var ch: char
begin
    ch := self.current
    return (ch >= "0") and (ch <= "9")
end Parser.isDigit

procedure Parser.read()
begin
    if self.current = 0AX then
        inc(self.line)
        self.column := 0
    end
    inc(self.index)
    if self.index < self.inputLen then
        self.current := self.input[self.index]
    else
        self.current := 0X
    end
end Parser.read

procedure Parser.readChar(ch: char): boolean
begin
    if self.current # ch then
        return false
    end
    self.read()
    return true
end Parser.readChar

procedure Parser.readRequiredChar(ch: char)
begin
    if not self.readChar(ch) then
        assert(false)
    end
end Parser.readRequiredChar

procedure Parser.readDigit(): boolean
begin
    if not self.isDigit() then
        return false
    end
    self.read()
    return true
end Parser.readDigit

procedure Parser.skipWhiteSpace()
begin
    while self.isWhiteSpace() do
       self.read()
    end
end Parser.skipWhiteSpace

procedure Parser.startCapture()
begin
    self.captureStart := self.index
end Parser.startCapture

procedure Parser.pauseCapture()
var end_: integer
begin
    if self.current = 0X then end_ := self.index
    else end_ := self.index - 1 end
    self.captureBuffer.append(self.input, self.captureStart, end_ + 1 - self.captureStart)
    self.captureStart := -1
end Parser.pauseCapture

procedure Parser.endCapture(): Str
var end_, captLen, i: integer; captured: Str
begin
    if self.current = 0X then end_ := self.index
    else end_ := self.index - 1 end
    self.captureBuffer.append(self.input, self.captureStart, end_ + 1 - self.captureStart)
    captLen := self.captureBuffer.pos
    new(captured, captLen + 1)
    for i := 0 to captLen - 1 do
        captured[i] := self.captureBuffer.buf[i]
    end
    captured[captLen] := 0X
    if self.captureBuffer.buf # nil then
        dispose(self.captureBuffer.buf)
    end
    self.captureBuffer.init()
    self.captureStart := -1
    return captured
end Parser.endCapture

procedure Parser.readEscape()
begin
    self.read()
    if self.current = '"' then
        self.captureBuffer.appendChar('"')
    elsif self.current = "/" then
        self.captureBuffer.appendChar("/")
    elsif self.current = 5CX then
        self.captureBuffer.appendChar(5CX)
    elsif self.current = "b" then
        self.captureBuffer.appendChar(8X)
    elsif self.current = "f" then
        self.captureBuffer.appendChar(0CX)
    elsif self.current = "n" then
        self.captureBuffer.appendChar(0AX)
    elsif self.current = "r" then
        self.captureBuffer.appendChar(0DX)
    elsif self.current = "t" then
        self.captureBuffer.appendChar(9X)
    else
        assert(false)
    end
    self.read()
end Parser.readEscape

procedure Parser.readStringInternal(): Str
var str: Str
begin
    self.read()
    self.startCapture()
    while self.current # '"' do
        if self.current = 5CX then
            self.pauseCapture()
            self.readEscape()
            self.startCapture()
        else
            self.read()
        end
    end
    str := self.endCapture()
    self.read()
    return str
end Parser.readStringInternal

procedure Parser.readFraction(): boolean
begin
    if not self.readChar(".") then
        return false
    end
    if not self.readDigit() then
        assert(false)
    end
    while self.readDigit() do end
    return true
end Parser.readFraction

procedure Parser.readExponent(): boolean
begin
    if (not self.readChar("e")) and (not self.readChar("E")) then
        return false
    end
    if not self.readChar("+") then
        self.readChar("-")
    end
    if not self.readDigit() then
        assert(false)
    end
    while self.readDigit() do end
    return true
end Parser.readExponent

procedure Parser.readNumber(): ^JsonValue
var firstDigit: char
begin
    self.startCapture()
    self.readChar("-")
    firstDigit := self.current
    if not self.readDigit() then
        assert(false)
    end
    if firstDigit # "0" then
        while self.readDigit() do end
    end
    self.readFraction()
    self.readExponent()
    return JsonNumber_create(self.endCapture())
end Parser.readNumber

procedure Parser.readName(): Str
begin
    if self.current # '"' then
        assert(false)
    end
    return self.readStringInternal()
end Parser.readName

procedure Parser.readString(): ^JsonValue
begin
    return JsonString_create(self.readStringInternal())
end Parser.readString

procedure Parser.readNull(): ^JsonValue
begin
    self.read()
    self.readRequiredChar("u")
    self.readRequiredChar("l")
    self.readRequiredChar("l")
    return self.nullValue
end Parser.readNull

procedure Parser.readTrue(): ^JsonValue
begin
    self.read()
    self.readRequiredChar("r")
    self.readRequiredChar("u")
    self.readRequiredChar("e")
    return self.trueValue
end Parser.readTrue

procedure Parser.readFalse(): ^JsonValue
begin
    self.read()
    self.readRequiredChar("a")
    self.readRequiredChar("l")
    self.readRequiredChar("s")
    self.readRequiredChar("e")
    return self.falseValue
end Parser.readFalse

procedure Parser.readArray(): ^JsonValue
var arr: ^JsonArray
begin
    self.read()
    arr := JsonArray_create()
    self.skipWhiteSpace()
    if self.readChar("]") then
        return arr
    end
    loop
        self.skipWhiteSpace()
        arr.add(self.readValue())
        self.skipWhiteSpace()
        if not self.readChar(",") then exit end
    end
    if not self.readChar("]") then
        assert(false)
    end
    return arr
end Parser.readArray

procedure Parser.readObject(): ^JsonValue
var obj: ^JsonObject; name: ^array of char
begin
    self.read()
    obj := JsonObject_create()
    self.skipWhiteSpace()
    if self.readChar("}") then
        return obj
    end
    loop
        self.skipWhiteSpace()
        name := self.readName()
        self.skipWhiteSpace()
        if not self.readChar(":") then
            assert(false)
        end
        self.skipWhiteSpace()
        obj.add(name, self.readValue())
        self.skipWhiteSpace()
        if not self.readChar(",") then exit end
    end
    if not self.readChar("}") then
        assert(false)
    end
    return obj
end Parser.readObject

procedure Parser.readValue(): ^JsonValue
begin
    if self.current = "n" then
        return self.readNull()
    elsif self.current = "t" then
        return self.readTrue()
    elsif self.current = "f" then
        return self.readFalse()
    elsif self.current = '"' then
        return self.readString()
    elsif self.current = "[" then
        return self.readArray()
    elsif self.current = "{" then
        return self.readObject()
    elsif (self.current = "-") or ((self.current >= "0") and (self.current <= "9")) then
        return self.readNumber()
    else
        assert(false)
        return nil
    end
end readValue

procedure Parser.parse(): ^JsonValue
var res: ^JsonValue
begin
    self.read()
    self.skipWhiteSpace()
    res := self.readValue()
    self.skipWhiteSpace()
    if self.current # 0X then
        assert(false)
    end
    return res
end Parser.parse

