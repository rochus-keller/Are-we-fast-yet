// TODO: returns ERROR

module CD

import B := Benchmark
import Math := Math

type
    Vector2D = record
        x, y: real
    end

    Vector3D = record
        x, y, z: real
    end

    CallSign = record
        value: integer
    end

    Aircraft = record
        callsign: CallSign
        position: Vector3D
    end

    Collision = record
        aircraftA: CallSign
        aircraftB: CallSign
        position: Vector3D
    end

    Motion = record
        callsign: CallSign
        posOne: Vector3D
        posTwo: Vector3D
    end

    RBNodeCSV3D = record
        key: CallSign
        value: Vector3D
        left, right, parent: ^RBNodeCSV3D
        color: integer
    end

    TreeCSV3D = record
        root: ^RBNodeCSV3D
    end

    RBNodeV2Bool = record
        key: Vector2D
        value: boolean
        left, right, parent: ^RBNodeV2Bool
        color: integer
    end

    TreeV2Bool = record
        root: ^RBNodeV2Bool
    end

    MotionArr = record
        data: ^array of Motion
        size, cap: integer
    end

    MotionArrPtr = record
        data: ^array of ^MotionArr
        size, cap: integer
    end

    RBNodeV2Motions = record
        key: Vector2D
        value: ^MotionArr
        left, right, parent: ^RBNodeV2Motions
        color: integer
    end

    TreeV2Motions = record
        root: ^RBNodeV2Motions
    end

    AircraftArr = record
        data: ^array of Aircraft
        size, cap: integer
    end

    CallSignArr = record
        data: ^array of CallSign
        size, cap: integer
    end

    CollisionArr = record
        data: ^array of Collision
        size, cap: integer
    end

    CollisionDetector = record
        state: ^TreeCSV3D
    end

    Simulator = record
        aircraft: ^CallSignArr
    end

const
    RB_RED = 0
    RB_BLACK = 1
    MIN_X = 0.0
    MIN_Y = 0.0
    MAX_X = 1000.0
    MAX_Y = 1000.0
    MIN_Z = 0.0
    MAX_Z = 10.0
    PROXIMITY_RADIUS = 1.0
    GOOD_VOXEL_SIZE = 2.0

procedure MotionArr_create(): ^MotionArr
var me: ^MotionArr
begin
    new(me)
    me.data := nil
    me.size := 0
    me.cap := 0
    return me
end MotionArr_create

procedure MotionArr_append(me: ^MotionArr; const m: ^Motion)
var old: ^array of Motion; i: integer
begin
    if me.size >= me.cap then
        if me.cap = 0 then me.cap := 4 else me.cap := me.cap * 2 end
        old := me.data
        new(me.data, me.cap)
        if old # nil then
            for i := 0 to me.size - 1 do me.data[i] := old[i] end
            dispose(old)
        end
    end
    me.data[me.size] := m^
    inc(me.size)
end MotionArr_append

procedure MotionArr_free(me: ^MotionArr)
begin
    if me = nil then return end
    if me.data # nil then dispose(me.data) end
    dispose(me)
end MotionArr_free

procedure MotionArrPtr_init(me: ^MotionArrPtr)
begin
    me.data := nil
    me.size := 0
    me.cap := 0
end MotionArrPtr_init

procedure MotionArrPtr_append(me: ^MotionArrPtr; p: ^MotionArr)
var old: ^array of ^MotionArr; i: integer
begin
    if me.size >= me.cap then
        if me.cap = 0 then me.cap := 4 else me.cap := me.cap * 2 end
        old := me.data
        new(me.data, me.cap)
        if old # nil then
            for i := 0 to me.size - 1 do me.data[i] := old[i] end
            dispose(old)
        end
    end
    me.data[me.size] := p
    inc(me.size)
end MotionArrPtr_append

procedure MotionArrPtr_free(me: ^MotionArrPtr)
begin
    if me.data # nil then dispose(me.data) end
end MotionArrPtr_free

